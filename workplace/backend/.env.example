# daily backend environment — copy to backend/.env and fill in.
# Only LLM/VL API keys are paid; everything else runs locally and free (NFR-2).

# --- DeepSeek (text LLM; required to run a real verify) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro

# --- Vision (pluggable Chinese VL; optional, best-effort) ---
# vl_provider: qwen_cloud | doubao | local_qwen  (local_qwen needs no key)
VL_PROVIDER=qwen_cloud
VL_API_KEY=
# region-specific; CN default. For intl use the dashscope-intl base URL.
VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VL_MODEL=qwen-vl-max
VL_LOCAL_MODEL=Qwen2.5-VL-7B-Instruct

# --- Local models (free) ---
WHISPER_MODEL_SIZE=medium
WHISPER_COMPUTE_TYPE=int8
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# --- Coverage toggles (best-effort, degradable) ---
ENABLE_PDF_TEXT=true
ENABLE_HTML_RENDER=false

# --- Local data paths ---
DATA_DIR=data
SQLITE_PATH=data/daily.db
CHROMA_PATH=data/chroma
